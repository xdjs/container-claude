# === Required ===
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="you@example.com"

# === Optional (defaults shown) ===
CONTAINER_NAME="claude-dev"
DOCKER_USER="dev"
WORKSPACE_DIR="workspace"
IMAGE_NAME="claude-code"
HOST_PORT="3000"

# Claude config mode: how to handle ~/.claude settings
#   "fresh" — empty start, log in interactively inside container (default)
#   "seed"  — copy host ~/.claude and ~/.claude.json into container on first run
#   "mount" — bind mount host config directly (shared state, changes affect host)
CLAUDE_CONFIG="fresh"

# === Secrets ===
# GH_TOKEN should be exported in your shell, not stored here.
# Example:  export GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
#
# If you do store it here, ensure .env is in .gitignore (it is by default).

# Claude auth tokens should be exported in your shell, not stored here.
# ANTHROPIC_AUTH_TOKEN is preferred (from `claude setup-token`).
# ANTHROPIC_API_KEY is an alternative (direct API key from console.anthropic.com).
# Precedence: ANTHROPIC_AUTH_TOKEN > ANTHROPIC_API_KEY > interactive /login
#
# Example:  export ANTHROPIC_AUTH_TOKEN=<token>
# Example:  export ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
